# Base URL of the application under test
BASE_URL=http://localhost:3000

# Test user data
TEST_REGISTERED_EMAIL=registered.user@example.com
TEST_REGISTERED_PASSWORD=CorrectPassword123!
TEST_UNREGISTERED_EMAIL=unregistered.user@example.com
TEST_WRONG_PASSWORD=WrongPassword!

# Optional: per-test reset links (recommended)
# RESET_LINK_TC_REQ002_01=https://...
# RESET_LINK_TC_REQ003_01=https://...

# Optional: global reset link fallbacks
# RESET_LINK_FRESH=https://...
# RESET_LINK_EXPIRED=https://...
# RESET_LINK_USED=https://...

# Optional: password history fixtures for REQ_005
# TEST_PASSWORD_HISTORY_1=OldPassword1A
# TEST_PASSWORD_HISTORY_2=OldPassword2B
# TEST_PASSWORD_HISTORY_3=OldPassword3C
# TEST_PASSWORD_NEW_NOT_IN_HISTORY=BrandNew4D

# Optional: override expected UI copy
# MSG_FORGOT_PASSWORD_CONFIRMATION=If an account exists...
# MSG_RESET_LINK_EXPIRED=This link has expired.
# MSG_RESET_TOKEN_INVALID=This link is invalid or has already been used.
# MSG_PASSWORD_RESET_SUCCESS=Your password has been reset successfully.
# MSG_INVALID_CREDENTIALS=Invalid email or password.
# MSG_ACCOUNT_LOCKED=Your account is locked.

# Optional: enable boundary tests requiring time control
# ENABLE_TIME_BOUNDARY_TESTS=true
# ACCOUNT_ALREADY_LOCKED=true
